# ─────────────────────────────────────────────────────────────────────────────
# This backend runs exclusively on the GCP VM. The ERP firewall whitelists
# only the VM's IP, so local execution is not supported.
#
# Frontend developers connect their local React app via SSH tunnel:
#   ssh -L 8000:localhost:8000 memla@<vm-ip>
#
# Required on the VM (all other secrets come from Secret Manager):
# ─────────────────────────────────────────────────────────────────────────────

# Required — used to locate secrets in Secret Manager
GCP_PROJECT_ID=tire-center-dev

# Required — Cloud SQL connection name for the managed DB
CLOUD_SQL_CONNECTION_NAME=tire-center-dev:me-west1:tire-center-dev-db

# DB credentials (non-sensitive identifiers only — password comes from Secret Manager)
DB_NAME=tiredb
DB_USER=tireuser

# Comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# ── ERP SOAP config ───────────────────────────────────────────────────────────
# WSDL advertises port 443 — firewall requires 22443
ERP_WSDL_URL=https://tet.kogol.co.il:22443/csp/bil/Diagnose.Webservices.cls?WSDL
ERP_ENDPOINT_URL=https://tet.kogol.co.il:22443/csp/bil/Diagnose.Webservices.cls
# Set true once the test server has a valid certificate
ERP_SSL_VERIFY=false
# Set true to include the OTP in the /request-code response (test env only — never in prod)
ERP_TEST_MODE=true
