# ─────────────────────────────────────────────────────────────────────────────
# ON THE GCP VM / CLOUD RUN:
#   Only GCP_PROJECT_ID is needed. All other secrets are pulled automatically
#   from Secret Manager using the VM/Cloud Run service account.
#
# FOR LOCAL DEV ONLY:
#   Set all variables below. DB_HOST/PORT point at a local postgres or a
#   Cloud SQL Auth Proxy running on localhost.
#   Leave GCP_PROJECT_ID blank to skip Secret Manager entirely.
# ─────────────────────────────────────────────────────────────────────────────

# Set this on the VM/Cloud Run to enable Secret Manager loading.
# Leave blank for local dev.
GCP_PROJECT_ID=tire-center-dev

# On GCP: set to the Cloud SQL connection name (e.g. tire-center-dev:me-west1:tire-center-dev-db)
# On local dev: leave blank (falls back to DB_HOST/PORT below)
CLOUD_SQL_CONNECTION_NAME=

# DB credentials (read from Secret Manager on GCP; set manually for local dev)
DB_NAME=tiredb
DB_USER=tireuser
DB_PASSWORD=

# Local dev only — ignored when CLOUD_SQL_CONNECTION_NAME is set
DB_HOST=localhost
DB_PORT=5432

# Set manually for local dev only — on GCP these come from Secret Manager
JWT_SECRET=
CAROOL_API_KEY=
CAROOL_PAGE_ORIGIN=
FIREBASE_SERVICE_ACCOUNT=   # path to JSON file, or paste JSON contents

# Comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# ── ERP SOAP config ───────────────────────────────────────────────────────────
# WSDL advertises port 443 — firewall requires 22443; both vars override the defaults.
ERP_WSDL_URL=https://tet.kogol.co.il:22443/csp/bil/Diagnose.Webservices.cls?WSDL
ERP_ENDPOINT_URL=https://tet.kogol.co.il:22443/csp/bil/Diagnose.Webservices.cls
# Set true once the test server has a valid certificate
ERP_SSL_VERIFY=false
# Set true to include the OTP in the /request-code response (test env only — never in prod)
ERP_TEST_MODE=true
